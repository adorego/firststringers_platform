{
  "name": "@firststringers/database",
  "version": "0.1.0",
  "main": "./index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../apps/api/.env -- prisma generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../apps/api/.env -- prisma db push",
    "db:studio": "dotenv -e ../../apps/api/.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.0.0"
  }
}
