# ─────────────────────────────────────────────────────────────
# firststringers_platform — Environment Variables
# Copy this file to .env and fill in your values.
# Lines marked REQUIRED will cause the app to crash on startup
# if missing. Lines marked OPTIONAL have working defaults.
# ─────────────────────────────────────────────────────────────

# ── Database (Prisma) ─────────────────────────────────────────
# REQUIRED — PostgreSQL connection string.
# Railway injects this automatically when you add a Postgres service.
DATABASE_URL="postgresql://postgres:password@localhost:5432/firststringers"

# ── Redis ─────────────────────────────────────────────────────
# REQUIRED — Used by BullModule (job queue) and RedisService.
# Railway injects this automatically when you add a Redis service.
# Must be a full URL so that Railway's auth token is included:
#   redis://:password@host:port
REDIS_URL="redis://localhost:6379"

# ── AI ────────────────────────────────────────────────────────
# REQUIRED — Validated on startup; app will not start without it.
# Used by LLMService for chat, extraction, and intent classification.
OPENAI_API_KEY="sk-proj-your-openai-key-here"

# ── Server ────────────────────────────────────────────────────
# OPTIONAL — Port the NestJS API listens on. Default: 3001.
# Railway overrides this automatically.
PORT="3001"

# OPTIONAL — Origin allowed for CORS (REST + WebSocket).
# Set to your frontend's public URL in staging/production.
# Default: http://localhost:3000
FRONTEND_URL="http://localhost:3000"
